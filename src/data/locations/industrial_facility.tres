enemy_types = ["swarmers", "blockers", "ranged", "elites"]
enemy_density = "high"
elite_chance = "25%"
environmental_hazards = ["moving_machinery", "toxic_chemicals", "electrical_hazards", "steam_vents", "unstable_structures"]
