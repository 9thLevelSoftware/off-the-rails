    "purpose": "High-value loot cache",
  },
  {
    "name": "Power Plant",
    "purpose": "Power cores, dangerous but rewarding",
  },
  {
    "name": "Maintenance Tunnels",
    "purpose": "Alternate routes, tight spaces",
  },
]
