[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D Base_Color_Texture : source_color;
uniform vec4 Skin_Color : source_color = vec4(1.000000, 1.000000, 1.000000, 1.000000);
uniform sampler2D Roughness_Texture;
uniform sampler2D Normal_Texture : hint_normal;



void fragment() {
	vec4 n_out5p0;
// Texture2D:5
	n_out5p0 = texture(Base_Color_Texture, UV);


// ColorParameter:4
	vec4 n_out4p0 = Skin_Color;


// VectorOp:3
	vec4 n_out3p0 = n_out5p0 * n_out4p0;


	vec4 n_out6p0;
// Texture2D:6
	n_out6p0 = texture(Roughness_Texture, UV);


	vec4 n_out9p0;
// Texture2D:9
	n_out9p0 = texture(Normal_Texture, UV);


// Output:0
	ALBEDO = vec3(n_out3p0.xyz);
	ROUGHNESS = n_out6p0.x;
	NORMAL_MAP = vec3(n_out9p0.xyz);


}
"
