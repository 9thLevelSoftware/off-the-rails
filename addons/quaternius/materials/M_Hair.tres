[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D Hair_Texture : source_color;
uniform vec4 Hair_Color : source_color = vec4(0.213952, 0.154740, 0.047221, 1.000000);
uniform float Roughness = 0.89999997615814;
uniform sampler2D Hair_Normal_Map : hint_normal;



void fragment() {
	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(Hair_Texture, UV);


// ColorParameter:5
	vec4 n_out5p0 = Hair_Color;


// VectorOp:4
	vec4 n_out4p0 = n_out3p0 * n_out5p0;


// FloatParameter:8
	float n_out8p0 = Roughness;


	vec4 n_out7p0;
// Texture2D:7
	n_out7p0 = texture(Hair_Normal_Map, UV);


// Output:0
	ALBEDO = vec3(n_out4p0.xyz);
	ROUGHNESS = n_out8p0;
	NORMAL_MAP = vec3(n_out7p0.xyz);


}
"
