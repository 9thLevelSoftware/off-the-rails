code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform bool Custom_Eye_Color = true;
uniform sampler2D tex_frg_2;
uniform vec4 Eye_Color : source_color = vec4(0.307164, 0.196635, 0.055389, 1.000000);
uniform sampler2D Eye_Texture : source_color;
uniform sampler2D tex_frg_14 : hint_normal;



void fragment() {
// BooleanParameter:13
	bool n_out13p0 = Custom_Eye_Color;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, UV);


// VectorDecompose:3
	float n_out3p0 = n_out2p0.x;
	float n_out3p1 = n_out2p0.y;
	float n_out3p2 = n_out2p0.z;
	float n_out3p3 = n_out2p0.w;


// ColorParameter:8
	vec4 n_out8p0 = Eye_Color;


// VectorOp:7
	vec4 n_out7p0 = vec4(n_out3p1) * n_out8p0;


// FloatOp:4
	float n_in4p1 = 5.00000;
	float n_out4p0 = n_out3p1 * n_in4p1;


// Clamp:5
	float n_in5p1 = 0.00000;
	float n_in5p2 = 1.00000;
	float n_out5p0 = clamp(n_out4p0, n_in5p1, n_in5p2);


// Mix:6
	vec4 n_out6p0 = mix(vec4(n_out3p0), n_out7p0, vec4(n_out5p0));


// VectorOp:9
	vec4 n_out9p0 = n_out6p0 + vec4(n_out3p2);


// Clamp:10
	vec4 n_in10p1 = vec4(0.00000, 0.00000, 0.00000, 0.00000);
	vec4 n_in10p2 = vec4(1.00000, 1.00000, 1.00000, 1.00000);
	vec4 n_out10p0 = clamp(n_out9p0, n_in10p1, n_in10p2);


	vec4 n_out16p0;
// Texture2D:16
	n_out16p0 = texture(Eye_Texture, UV);


	vec4 n_out19p0;
// Switch:19
	n_out19p0 = mix(n_out16p0, n_out10p0, float(n_out13p0));


// FloatConstant:17
	float n_out17p0 = 0.000000;


// FloatConstant:18
	float n_out18p0 = 0.000000;


// Texture2D:14
	vec4 n_out14p0 = texture(tex_frg_14, UV);


// Output:0
	ALBEDO = vec3(n_out19p0.xyz);
	ROUGHNESS = n_out17p0;
	SPECULAR = n_out18p0;
	NORMAL_MAP = vec3(n_out14p0.xyz);


}
